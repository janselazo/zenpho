# Supabase (Agency CRM + auth) — from Project Settings → API
# Project ref (for CLI): lyvmiueigkksozyvvxpy
NEXT_PUBLIC_SUPABASE_URL=https://lyvmiueigkksozyvvxpy.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Required for the booking calendar (public /api/book inserts leads + appointments bypassing RLS)
SUPABASE_SERVICE_ROLE_KEY=

# Required to save Twilio or SendGrid under Settings → Integrations (encrypts tokens in Postgres).
# Generate: openssl rand -hex 32   (64 hex chars). Also set on Vercel → Environment Variables for production.
# INTEGRATION_SECRETS_KEY=

# Twilio — either set these on the server (e.g. Vercel) or use Settings → Integrations → Twilio (encrypted in DB).
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_SECRET_KEY=   # optional alias for TWILIO_AUTH_TOKEN if you only set one
# TWILIO_FROM_PHONE=+15551234567
# After deploy: logged-in agency staff can GET /api/integrations/twilio-env to see which Twilio env vars the server sees (booleans only).
# Optional: canonical public origin for webhook URLs + Twilio signature validation (e.g. https://yourdomain.com)
# PUBLIC_APP_URL=

# Optional: Postgres URI (Dashboard → Database) for CLI when linked push fails (IPv6 / network) or for one-off queries.
# Copy to .env.local (never commit). Append ?sslmode=require if missing.
# DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.lyvmiueigkksozyvvxpy.supabase.co:5432/postgres?sslmode=require
#
# Migrations — recommended: npm run supabase:login → npm run supabase:link → npm run supabase:db:push
# If that fails, set DATABASE_URL in .env.local (session/direct URI; avoid transaction pooler for DDL) and run npm run supabase:db:push again.

# Optional: Prospecting → Prospects (Google Places Text Search). Server-only; enable Places API in Google Cloud.
# GOOGLE_PLACES_API_KEY=
# Optional: Prospecting → contact enrichment (server-only)
# OUTSCRAPER_API_KEY=     # Google Maps-style search via Outscraper (api.app.outscraper.com)
# APOLLO_API_KEY=         # Master API key REQUIRED (Settings → API). Used by People Search, /people/match enrichment,
#                         # AND mixed_companies/search (Prospecting → Tech Startups tab). Consumes credits.
# HUNTER_API_KEY=         # Domain email discovery (api.hunter.io)

# Optional: Prospecting → Reddit Communities tab (app-only OAuth2).
# Create a "script" app at https://www.reddit.com/prefs/apps → set redirect URI to http://localhost:3000.
# REDDIT_USER_AGENT is required by Reddit ToS and must uniquely identify your app, e.g.
#   "zenpho:prospecting:v1 (by u/your-handle)".
# REDDIT_CLIENT_ID=
# REDDIT_CLIENT_SECRET=
# REDDIT_USER_AGENT=zenpho:prospecting:v1 (by u/your-handle)

# Optional: Prospecting → Tech Startups → Signal Monitoring.
# These power on-demand tabs and the scheduled monitor route. Missing keys show setup warnings in the UI.
# Funding:
# CRUNCHBASE_API_KEY=
# WELLFOUND_API_KEY=        # Wellfound/AngelList access is limited; app falls back to SERPER_API_KEY public search when available.
# Launches:
# PRODUCT_HUNT_ACCESS_TOKEN=
# Social intent:
# X_BEARER_TOKEN=
# META_GRAPH_ACCESS_TOKEN=
# META_GROUP_IDS=123456789,987654321
# LINKEDIN_ACCESS_TOKEN=    # Only for approved LinkedIn APIs.
# LINKEDIN_CLIENT_ID=
# LINKEDIN_CLIENT_SECRET=
# SERPER_API_KEY=           # Used for compliant public web search across LinkedIn public posts, Indie Hackers, Wellfound fallback, and TechCrunch fallback.
# Scheduled monitor:
# CRON_SECRET=
# STARTUP_SIGNAL_CRON_CHANNELS=funding,launches,social_intent
# STARTUP_SIGNAL_CRON_SOURCES=crunchbase,product_hunt,linkedin_public,x_twitter,reddit,indie_hackers

# Optional: Prospecting → Networking (Ticketmaster Discovery API). Server-only; key from developer.ticketmaster.com
# TICKETMASTER_API_KEY=
# Optional: future LLM narratives for prospect intel (not wired in MVP).
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# Prospect website preview: uses ANTHROPIC_API_KEY (Claude) when set; otherwise OPENAI_API_KEY. Optional:
# ANTHROPIC_PROSPECT_PREVIEW_MODEL=claude-sonnet-4-20250514
# OPENAI_PROSPECT_PREVIEW_MODEL=gpt-4o-mini
# Prospecting → AI audit → Generate report (PDF): uses ANTHROPIC_API_KEY then OPENAI_API_KEY (same as preview).
# Narrative sections (opportunities, problems, solutions, gaps). Without keys, PDF is research-only (summary + bullets).
# AUTOMATION_REPORT_LLM_BUDGET_MS=45000
# AUTOMATION_REPORT_MAX_TOKENS=3072
# ANTHROPIC_AUTOMATION_REPORT_MODEL=claude-sonnet-4-20250514
# OPENAI_AUTOMATION_REPORT_MODEL=gpt-4o-mini
# Prospecting → Brand guidelines → Generate brand guidelines (PDF): ANTHROPIC_API_KEY (copy) then OPENAI_API_KEY (copy + images).
# NOTE: gpt-image-2 (ChatGPT Images 2.0) requires API org verification in the OpenAI dashboard before image calls succeed.
# If gpt-image-2 is unavailable on your account, the action auto-falls-back to OPENAI_BRANDING_IMAGE_MODEL_FALLBACK (default gpt-image-1).
# Without any key the PDF still renders with vector placeholders instead of AI-generated imagery.
# OPENAI_BRANDING_TEXT_MODEL=gpt-4o-mini
# OPENAI_BRANDING_IMAGE_MODEL=gpt-image-2   # canonical id; gpt-image-2-latest is NOT a valid alias and returns model_not_found
# OPENAI_BRANDING_IMAGE_MODEL_FALLBACK=gpt-image-1
# OPENAI_BRANDING_IMAGE_QUALITY=medium   # low | medium | high | auto
# OPENAI_BRANDING_IMAGE_TIMEOUT_MS=180000
# BRANDING_IMAGE_BATCH_MODE=false   # true attempts a single n=7 batched gpt-image-2 call; false runs 7 parallel calls (default, more reliable mapping)
# OPENAI_BRANDING_IMAGE_FAST_MODE=true   # default true; parallelizes the 7 brand-book image slots and falls back per-slot on failure
# Sales Funnel section (Brand Kit + Sales Funnel PDF): drives the 6 paid-ads + landing-hero gpt-image-2 slots.
# OPENAI_ADS_IMAGE_QUALITY=medium   # low | medium | high | auto
# OPENAI_ADS_IMAGE_FAST_MODE=true   # default true; parallelizes funnel image generation so PDFs fit inside function timeout
# BRANDING_GENERATE_LEGACY_IMAGES=true   # default true; set false to skip older decorative brand-book images and use placeholders
# Logo extraction from the prospect's website is bounded to PNG/JPEG only and capped at this byte size (default 1.5 MB).
# BRANDING_LOGO_FETCH_MAX_BYTES=1500000
# PROSPECT_PREVIEW_COLOR_VIBE=Fresh, professional palette with one accent…
# Public /preview/[id] needs SUPABASE_SERVICE_ROLE_KEY for screenshots via the service client.
# Vercel: set keys on Production (and Preview if you test there); redeploy after edits.
# On VERCEL=1 the preview LLM defaults to ~52s timeout and 4096 output tokens so the function returns JSON before
# the platform kills long requests (HTML 500). Override with:
# PROSPECT_PREVIEW_LLM_BUDGET_MS=110000
# PROSPECT_PREVIEW_MAX_TOKENS=8192
# …if your plan’s maxDuration allows (e.g. Pro + /api/prospecting/generate-preview maxDuration).
# PUBLIC_APP_URL=https://yourdomain.com
# Prospect preview iframe + pretty links:
# — Set PUBLIC_APP_URL to the CRM origin you use in the browser (include https://). Apex + www are added for embedding.
# — Optional PREVIEW_PUBLIC_HOST=preview.zenpho.com (hostname only). Add the domain in Vercel → Domains; DNS CNAME preview → cname.vercel-dns.com
#   Then public links become https://preview.zenpho.com/{slug-from-business-name}; middleware rewrites to the same app.
# — Optional PREVIEW_FRAME_ANCESTORS=https://other-origin.com (comma-separated) if the CRM runs on another host (e.g. a Vercel preview URL).
# Google Stitch (Prospecting → web/mobile UI concepts)
# — Visual direction for Stitch prompts uses PROSPECT_PREVIEW_COLOR_VIBE when set (same as prospect preview LLM); otherwise a built-in default.
# — Local Business listings: name, categories, rating, address, etc. come from the Google Business Profile payload (no manual services field in the CRM).
# — MCP in Cursor only affects the IDE. The hosted app cannot use your MCP connection from the browser.
# — No server key? Use “Copy prompt & open Google Stitch” in the CRM (works without STITCH_API_KEY).
# — One-click “Generate … in Google Stitch” uses @google/stitch-sdk on the server (HTTP API), not Cursor MCP.
# — Google API key with Stitch API enabled (see Google Cloud / stitch.withgoogle.com docs).
# — Optional alias if you already use another name: GOOGLE_STITCH_API_KEY= (same value; either var works).
# — Do not wrap the key in quotes. Restart `npm run dev` after changing .env.local.
# — Production: Vercel → Environment Variables, then redeploy.
# STITCH_API_KEY=
# GOOGLE_STITCH_API_KEY=
# Optional: numeric Stitch project ID — new screens are added here instead of creating a project each run.
# Example URL → ID: https://stitch.withgoogle.com/projects/8662667313370321523 → 8662667313370321523
# Same API key must be allowed to edit that project (same Google account as in stitch.withgoogle.com).
# Alias: STITCH_DEFAULT_PROJECT_ID
# STITCH_PROJECT_ID=
# STITCH_DEFAULT_PROJECT_ID=
# Optional: Stitch web app origin for “Open in Stitch” (defaults to https://stitch.withgoogle.com).
# “Open in Stitch” uses {origin}/projects/{projectId}. No trailing path required.
# NEXT_PUBLIC_STITCH_APP_URL=
# MICROLINK_API_KEY=        # recommended for prospect thumbnails; screenshot fetches PUBLIC_APP_URL/preview/<uuid>
# BLOB_READ_WRITE_TOKEN=
# Outbound CRM email (prospect preview “Send email”): SendGrid via env OR Settings → Integrations; else Resend when set.
# SENDGRID_API_KEY=
# SENDGRID_FROM_EMAIL=you@verified-domain.com
# SENDGRID_FROM_NAME=
# SENDGRID_REPLY_TO=
# Inbound email: SendGrid Inbound Parse webhook URL token (random secret for /api/webhooks/sendgrid/inbound?token=<this>)
# Generate: openssl rand -hex 20
# SENDGRID_INBOUND_WEBHOOK_SECRET=
# RESEND_API_KEY=
# RESEND_FROM_EMAIL=onboarding@resend.dev
#
# Lead Magnets (Agency → /lead-magnets): OpenAI + Google SERP via Serper (server-only).
# OPENAI_API_KEY=          # required for dynamic generation
# SERPER_API_KEY=          # from serper.dev — parallel web snippets (Reddit / Google-style / niche queries)
# OPENAI_LEAD_MAGNET_MODEL=gpt-4o-mini   # optional; must support JSON schema / structured outputs

# Optional: CRM → Referrals page → Reviews tab (public listing URLs)
# NEXT_PUBLIC_REVIEW_URL_GOOGLE=
# NEXT_PUBLIC_REVIEW_URL_CLUTCH=
# NEXT_PUBLIC_REVIEW_URL_YELP=

# --- Local dev (optional) ---
# If you still see EMFILE / "too many open files" after `npm run dev`, try polling watchers (slower):
# WATCHPACK_POLLING=true
