# Supabase (Agency CRM + auth) — from Project Settings → API
# Project ref (for CLI): lyvmiueigkksozyvvxpy
NEXT_PUBLIC_SUPABASE_URL=https://lyvmiueigkksozyvvxpy.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Required for the booking calendar (public /api/book inserts leads + appointments bypassing RLS)
SUPABASE_SERVICE_ROLE_KEY=

# Optional: Postgres URI (Dashboard → Database) for CLI when linked push fails (IPv6 / network) or for one-off queries.
# Copy to .env.local (never commit). Append ?sslmode=require if missing.
# DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.lyvmiueigkksozyvvxpy.supabase.co:5432/postgres?sslmode=require
#
# Migrations — recommended: npm run supabase:login → npm run supabase:link → npm run supabase:db:push
# If that fails, set DATABASE_URL in .env.local (session/direct URI; avoid transaction pooler for DDL) and run npm run supabase:db:push again.

# Optional: CRM → Referrals page → Reviews tab (public listing URLs)
# NEXT_PUBLIC_REVIEW_URL_GOOGLE=
# NEXT_PUBLIC_REVIEW_URL_CLUTCH=
# NEXT_PUBLIC_REVIEW_URL_YELP=
