# Public embed URL for the contact page booking calendar (iframe `src`).
# Cal.com: https://cal.com/yourusername/meeting-type
# Calendly: https://calendly.com/yourname/meeting-type?embed_domain=...
NEXT_PUBLIC_BOOKING_EMBED_URL=

# Supabase (Agency CRM + auth) — from Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Optional: server-only, bypasses RLS — use only for admin scripts / invites
# SUPABASE_SERVICE_ROLE_KEY=
